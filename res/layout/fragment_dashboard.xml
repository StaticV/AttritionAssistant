<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_farm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:counterColor="@android:color/holo_green_light"
        app:counterLabel="@string/label_farm" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_mill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_orange_dark"
        app:counterLabel="@string/label_mill" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_quarry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_blue_light"
        app:counterLabel="@string/label_quarry" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_stable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_purple"
        app:counterLabel="@string/label_stable" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_forge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_red_light"
        app:counterLabel="@string/label_forge" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_palace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_orange_light"
        app:counterLabel="@string/label_palace" />

</LinearLayout>