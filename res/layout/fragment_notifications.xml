<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_farmer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:counterColor="@android:color/holo_green_light"
        app:counterLabel="@string/label_farmer" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_archer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_orange_dark"
        app:counterLabel="@string/label_archer" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_rider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_blue_light"
        app:counterLabel="@string/label_rider" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_knight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_purple"
        app:counterLabel="@string/label_knight" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_sworder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_red_light"
        app:counterLabel="@string/label_sword" />

    <com.github.staticv.attritionassistant.ui.CounterView
        android:id="@+id/counter_piker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterColor="@android:color/holo_orange_light"
        app:counterLabel="@string/label_piker" />

</LinearLayout>